using System.Net.Http.Json;
using UTB.Minute.Contracts.Meals;
using UTB.Minute.Contracts.MenuItems;
using UTB.Minute.Contracts.Orders;

namespace UTB.Minute.AdminClient.Services;

public class ApiClient
{
    private readonly HttpClient _httpClient;

    public ApiClient(HttpClient httpClient)
    {
        _httpClient = httpClient;
    }

    // Meals
    public async Task<List<MealDto>> GetMealsAsync()
    {
        return await _httpClient.GetFromJsonAsync<List<MealDto>>("/meals") ?? [];
    }

    public async Task<MealDto?> GetMealByIdAsync(int id)
    {
        return await _httpClient.GetFromJsonAsync<MealDto>($"/meals/{id}");
    }

    public async Task<MealDto?> CreateMealAsync(CreateMealDto createMealDto)
    {
        var response = await _httpClient.PostAsJsonAsync("/meals", createMealDto);
        if (response.IsSuccessStatusCode)
        {
            return await response.Content.ReadAsAsync<MealDto>();
        }
        return null;
    }

    public async Task<bool> UpdateMealAsync(int id, UpdateMealDto updateMealDto)
    {
        var response = await _httpClient.PutAsJsonAsync($"/meals/{id}", updateMealDto);
        return response.IsSuccessStatusCode;
    }

    // Menu Items
    public async Task<List<MenuItemDto>> GetMenuItemsAsync()
    {
        return await _httpClient.GetFromJsonAsync<List<MenuItemDto>>("/menu-items") ?? [];
    }

    public async Task<List<MenuItemDto>> GetTodayMenuItemsAsync()
    {
        return await _httpClient.GetFromJsonAsync<List<MenuItemDto>>("/menu-items/today") ?? [];
    }

    public async Task<MenuItemDto?> GetMenuItemByIdAsync(int id)
    {
        return await _httpClient.GetFromJsonAsync<MenuItemDto>($"/menu-items/{id}");
    }

    public async Task<MenuItemDto?> CreateMenuItemAsync(CreateMenuItemDto createMenuItemDto)
    {
        var response = await _httpClient.PostAsJsonAsync("/menu-items", createMenuItemDto);
        if (response.IsSuccessStatusCode)
        {
            return await response.Content.ReadAsAsync<MenuItemDto>();
        }
        return null;
    }

    public async Task<bool> UpdateMenuItemAsync(int id, UpdateMenuItemDto updateMenuItemDto)
    {
        var response = await _httpClient.PutAsJsonAsync($"/menu-items/{id}", updateMenuItemDto);
        return response.IsSuccessStatusCode;
    }

    public async Task<bool> DeleteMenuItemAsync(int id)
    {
        var response = await _httpClient.DeleteAsync($"/menu-items/{id}");
        return response.IsSuccessStatusCode;
    }

    // Orders
    public async Task<List<OrderDto>> GetOrdersAsync()
    {
        return await _httpClient.GetFromJsonAsync<List<OrderDto>>("/orders") ?? [];
    }

    public async Task<List<OrderDto>> GetActiveOrdersAsync()
    {
        return await _httpClient.GetFromJsonAsync<List<OrderDto>>("/orders/active") ?? [];
    }

    public async Task<OrderDto?> GetOrderByIdAsync(int id)
    {
        return await _httpClient.GetFromJsonAsync<OrderDto>($"/orders/{id}");
    }

    public async Task<OrderDto?> CreateOrderAsync(CreateOrderDto createOrderDto)
    {
        var response = await _httpClient.PostAsJsonAsync("/orders", createOrderDto);
        if (response.IsSuccessStatusCode)
        {
            return await response.Content.ReadAsAsync<OrderDto>();
        }
        return null;
    }

    public async Task<bool> UpdateOrderStateAsync(int id, UpdateOrderStateDto updateOrderStateDto)
    {
        var response = await _httpClient.PutAsJsonAsync($"/orders/{id}/state", updateOrderStateDto);
        return response.IsSuccessStatusCode;
    }
}
