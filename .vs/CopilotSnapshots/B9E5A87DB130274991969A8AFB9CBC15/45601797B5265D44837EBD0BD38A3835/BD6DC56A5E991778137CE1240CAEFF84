@using UTB.Minute.CanteenClient.Services

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid d-flex justify-content-between align-items-center">
        <a class="navbar-brand" href="">Minute</a>
        <div class="d-flex gap-2 align-items-center">
            <span class="text-light me-2">
                @(Auth.IsStudent ? "Student" : "Canteen Worker")
            </span>
            <button class="btn btn-sm btn-outline-light" @onclick="SwitchRole">
                Switch Role
            </button>
        </div>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Home
            </NavLink>
        </div>

        @if (Auth.IsStudent)
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="order-meal">
                    <span class="bi bi-cart-fill-nav-menu" aria-hidden="true"></span> Order Meal
                </NavLink>
            </div>

            <div class="nav-item px-3">
                <NavLink class="nav-link" href="my-orders">
                    <span class="bi bi-clipboard-check-fill-nav-menu" aria-hidden="true"></span> My Orders
                </NavLink>
            </div>
        }
        else
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="manage-orders">
                    <span class="bi bi-list-check-nav-menu" aria-hidden="true"></span> Manage Orders
                </NavLink>
            </div>
        }
    </nav>
</div>

@code {
    [Inject]
    private AuthService Auth { get; set; } = default!;

    private void SwitchRole()
    {
        Auth.SwitchRole();
    }
}
