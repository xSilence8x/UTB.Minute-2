@page "/"

<PageTitle>Minute - Admin Dashboard</PageTitle>

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col">
            <h1>Dashboard</h1>
            <p class="text-muted">Welcome to the Minute canteen management system</p>
        </div>
    </div>

    <div class="row">
        <div class="col-md-3 mb-4">
            <div class="card text-center">
                <div class="card-body">
                    <h5 class="card-title">Meals</h5>
                    <p class="card-text text-muted">Manage meals and their information</p>
                    <a href="/meals" class="btn btn-primary">Go to Meals</a>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-4">
            <div class="card text-center">
                <div class="card-body">
                    <h5 class="card-title">Menu</h5>
                    <p class="card-text text-muted">Manage daily menu items</p>
                    <a href="/menu-items" class="btn btn-primary">Go to Menu</a>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-4">
            <div class="card text-center">
                <div class="card-body">
                    <h5 class="card-title">Orders</h5>
                    <p class="card-text text-muted">View all student orders</p>
                    <a href="/orders" class="btn btn-primary">Go to Orders</a>
                </div>
            </div>
        </div>
    </div>
</div>
