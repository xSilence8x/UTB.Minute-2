@page "/"
@using UTB.Minute.CanteenClient.Services
@inject AuthService Auth

<PageTitle>Minute - Canteen System</PageTitle>

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col">
            <h1>Welcome to Minute</h1>
            <p class="text-muted">Canteen management and ordering system</p>
        </div>
    </div>

    <div class="alert alert-info">
        <strong>Current Role:</strong> @(Auth.IsStudent ? "Student" : "Canteen Worker")
    </div>

    @if (Auth.IsStudent)
    {
        <div class="row">
            <div class="col-md-6 mb-4">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">Order a Meal</h5>
                        <p class="card-text">Browse today's menu and order your meal</p>
                        <a href="/order-meal" class="btn btn-primary">Order Now</a>
                    </div>
                </div>
            </div>

            <div class="col-md-6 mb-4">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">My Orders</h5>
                        <p class="card-text">View the status of your orders</p>
                        <a href="/my-orders" class="btn btn-primary">View Orders</a>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="row">
            <div class="col-md-12 mb-4">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">Manage Orders</h5>
                        <p class="card-text">Prepare meals and update order status</p>
                        <a href="/manage-orders" class="btn btn-primary">Manage Orders</a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
