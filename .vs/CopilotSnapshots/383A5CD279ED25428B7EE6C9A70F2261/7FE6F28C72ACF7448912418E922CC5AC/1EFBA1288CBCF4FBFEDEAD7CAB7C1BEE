using Aspire.Hosting;
using Aspire.Hosting.PostgreSQL;
using Aspire.Hosting.Keycloak;

var builder = DistributedApplication.CreateBuilder(args);

// Add PostgreSQL database
var postgres = builder.AddPostgres("postgres")
    .AddDatabase("minute-db", "minute");

// Add Keycloak for authentication
var keycloak = builder.AddKeycloak("keycloak")
    .WithInitialAdminUser(username: "admin", password: "admin")
    .WithInitialRealm(new()
    {
        Realm = "minute",
        DisplayName = "Minute",
        Enabled = true,
        Users =
        [
            new()
            {
                Username = "student",
                Password = "student",
                Email = "student@example.com",
                FirstName = "Student",
                LastName = "Test"
            },
            new()
            {
                Username = "cook",
                Password = "cook",
                Email = "cook@example.com",
                FirstName = "Cook",
                LastName = "Test"
            },
            new()
            {
                Username = "admin",
                Password = "admin",
                Email = "admin@example.com",
                FirstName = "Admin",
                LastName = "Test"
            }
        ]
    });

// Add WebAPI with PostgreSQL reference
var webApi = builder.AddProject<Projects.UTB_Minute_WebApi>("webapi")
    .WithHttpHealthCheck("/health")
    .WithReference(postgres)
    .WithReference(keycloak)
    .WaitFor(postgres)
    .WaitFor(keycloak);

// Add CanteenClient (for students and cooks)
builder.AddProject<Projects.UTB_Minute_CanteenClient>("canteenclient")
    .WithExternalHttpEndpoints()
    .WithHttpHealthCheck("/health")
    .WithReference(webApi)
    .WithReference(keycloak)
    .WaitFor(webApi)
    .WaitFor(keycloak);

// Add AdminClient (for canteen management)
builder.AddProject<Projects.UTB_Minute_AdminClient>("adminclient")
    .WithExternalHttpEndpoints()
    .WithHttpHealthCheck("/health")
    .WithReference(webApi)
    .WithReference(keycloak)
    .WaitFor(webApi)
    .WaitFor(keycloak);

// Add DbManager for database management
builder.AddProject<Projects.UTB_Minute_DbManager>("dbmanager")
    .WithReference(webApi)
    .WithReference(postgres)
    .WaitFor(postgres)
    .WaitFor(webApi);

builder.Build().Run();
